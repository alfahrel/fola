<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Fola" parent="Theme.Material3Expressive.Light.NoActionBar">
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>

        <item name="android:navigationBarColor">
            @android:color/transparent
        </item>

        <item name="android:statusBarColor">
            @android:color/transparent
        </item>

        <item name="android:windowLightStatusBar">
            true
        </item>
    </style>
    <style name="BoldTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/poppins_bold</item>
    </style>

    <style name="BoldDisplayTitle" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/poppins_bold</item>
    </style>

    <style name="DayLabelStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textAppearance">?attr/textAppearanceLabelSmall</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>


    <style name="ThemeOverlay.Fola.Default" parent="">
        <item name="colorPrimary">#3E6A00</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#BAFA76</item>
        <item name="colorOnPrimaryContainer">#112000</item>
        <item name="colorPrimaryFixed">#BAFA76</item>
        <item name="colorPrimaryFixedDim">#9FDD5D</item>
        <item name="colorOnPrimaryFixed">#112000</item>
        <item name="colorOnPrimaryFixedVariant">#2D5000</item>

        <item name="colorSecondary">#506440</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#D2EABC</item>
        <item name="colorOnSecondaryContainer">#0E1F04</item>
        <item name="colorSecondaryFixed">#D2EABC</item>
        <item name="colorSecondaryFixedDim">#B6CDA1</item>
        <item name="colorOnSecondaryFixed">#0E1F04</item>
        <item name="colorOnSecondaryFixedVariant">#394C2A</item>

        <item name="colorTertiary">#386666</item>
        <item name="colorOnTertiary">#FFFFFF</item>
        <item name="colorTertiaryContainer">#BBECEB</item>
        <item name="colorOnTertiaryContainer">#002020</item>
        <item name="colorTertiaryFixed">#BBECEB</item>
        <item name="colorTertiaryFixedDim">#9FCFCF</item>
        <item name="colorOnTertiaryFixed">#002020</item>
        <item name="colorOnTertiaryFixedVariant">#1F4E4E</item>

        <item name="colorSurface">#F8FAEE</item>
