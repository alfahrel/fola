<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".util.App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Base.Theme.Fola">

        <activity
            android:name=".ui.home.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Base.Theme.Fola">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.calendar.CalendarActivity"
            android:exported="false"
            android:theme="@style/Base.Theme.Fola"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.exportimport.ExportImportActivity"
            android:exported="false"
            android:theme="@style/Base.Theme.Fola"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.language.LanguageActivity"
            android:exported="false"
            android:theme="@style/Base.Theme.Fola"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.about.AboutActivity"
            android:exported="false"
            android:theme="@style/Base.Theme.Fola"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".widget.TaskWidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Base.Theme.Fola">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.theme.ThemeActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <receiver
            android:name=".widget.TaskWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="alfahrel.my.id.fola.TOGGLE_TASK" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_task_info" />
        </receiver>

        <service
            android:name=".widget.TaskWidgetService"
            android:theme="@style/Base.Theme.Fola"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <receiver
            android:name=".widget.CalendarWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="alfahrel.my.id.kalender.WIDGET_PREV" />
                <action android:name="alfahrel.my.id.kalender.WIDGET_NEXT" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_calendar_info" />
        </receiver>

        <service
            android:name=".widget.CalendarWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

    </application>

</manifest>